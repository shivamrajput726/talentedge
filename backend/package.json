{
  "name": "backend",
  "version": "1.0.0",
  "description": "ADR Forge API (Express + Prisma + BullMQ + OpenAI)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "@prisma/client": "^6.17.0",
    "bullmq": "^5.58.3",
    "helmet": "^8.1.0",
    "openai": "^6.27.0",
    "pino": "^9.11.0",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prisma": "^6.17.0",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.56.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
