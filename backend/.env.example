## Server
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=info

## Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adrforge?schema=public

## Queue (Redis)
REDIS_URL=redis://localhost:6379

## AI
# Set to "stub" to run without external API calls (great for demos/screenshots).
AI_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

